generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Girl {
  id            String    @id @default(cuid())
  name          String
  origin        String?
  hometown      String?
  occupation    String?
  startDate     DateTime?
  endDate       DateTime?
  ranking       Float
  notes         String?
  status        Status    @default(ACTIVE)
  matchedDate   DateTime?
  matchedApp    String?
  firstWhatsapp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]
}

model Comment {
  id          String   @id @default(cuid())
  girlId      String
  girl        Girl     @relation(fields: [girlId], references: [id], onDelete: Cascade)
  role        String   // "OWNER" or "ADMIN"
  authorName  String?
  text        String
  createdAt   DateTime @default(now())
}

enum Role {
  OWNER
  ADMIN
}

enum Status {
  ACTIVE
  PAST
}
